---
// src/pages/home.astro
import Layout from "../layouts/Layout.astro";
---

<Layout title="Inicio - No Brand Studio">
  <header class="frame"></header>
  <div class="logo fixed">
    <span class="dif">No Brand Studio.</span>
  </div>
  <!-- ==========================================
       1. TU CÓDIGO DECORATIVO DE FONDO AQUÍ
       ========================================== -->
  <div class="bg-decorative" style="opacity: 0.1;">
    <div class="group">
      <div class="el pos-3" data-alt-pos="pos-8">Dormant voltage</div>
      <div
        class="el pos-3 typing-indicator"
        data-alt-pos="pos-3"
        data-scramble-duration="0"
      >
        █
      </div>
      <a class="el pos-3" data-alt-pos="pos-3" data-scramble-duration="0"> .</a>

      <h1 class="frame__title flex-end">
        <div
          class="el pos-1 typing-indicator"
          data-alt-pos="pos-3"
          data-scramble-duration="0"
        >
          █
        </div>
      </h1>
      <div
        class="el pos-1 typing-indicator"
        data-alt-pos="pos-3"
        data-scramble-duration="0"
      >
        █
      </div>
      <a
        class="frame__archive el pos-2"
        href="https://tympanus.net/codrops/hub/"
        >multidiciplinario
      </a>

      <a class="frame__github el pos-2" href="#">GitHub</a>
      <nav class="frame__tags el pos-2">
        <a href="#">#scroll</a>
        <a href="#">#typography</a>
        <a href="#">#gsap</a>
      </nav>
    </div>

    <!-- Contenedor de todos los textos animados -->
    <div class="content">
      <div class="group">
        <div class="el pos-4" data-alt-pos="pos-2">Signal</div>
        <div class="el pos-4" data-alt-pos="pos-2">Vacant orbit</div>
        <div class="el pos-4" data-alt-pos="pos-2">Quantum waves</div>
      </div>
      <div class="group">
        <div class="el pos-1" data-alt-pos="pos-3">Neural glow</div>
        <div class="el pos-1" data-alt-pos="pos-3">Micro distortions</div>
        <div class="el pos-1" data-alt-pos="pos-3">Data streams</div>
        <div class="el pos-1" data-alt-pos="pos-3">Spark</div>
        <div class="el pos-1" data-alt-pos="pos-3">Cold radiance</div>
      </div>

      <div class="group">
        <div
          class="el el--xl pos-1"
          data-alt-pos="pos-2"
          data-scramble-duration="2.5"
        >
          M
        </div>
      </div>
      <div class="group">
        <div class="el pos-1" data-alt-pos="pos-3" data-scramble-duration="0">
        </div>
        <div
          class="el pos-1 typing-indicator"
          data-alt-pos="pos-3"
          data-scramble-duration="0"
        >
        </div>
      </div>
      <div class="group">
        <div class="el pos-4" data-alt-pos="pos-2">Signal</div>
        <div class="el pos-4" data-alt-pos="pos-2">Vacant orbit</div>
        <div class="el pos-4" data-alt-pos="pos-2">Quantum waves</div>
      </div>
      <div class="group">
        <div class="el pos-1" data-alt-pos="pos-3">Neural glow</div>
        <div class="el pos-1" data-alt-pos="pos-3">Micro distortions</div>
        <div class="el pos-1" data-alt-pos="pos-3">Data streams</div>
        <div class="el pos-1" data-alt-pos="pos-3">Spark</div>
        <div class="el pos-1" data-alt-pos="pos-3">Cold radiance</div>
      </div>
      <!-- ... Continúa pegando los demás grupos aquí ... -->
    </div>
  </div>
  <!-- FIN DE LA DECORACIÓN -->

  <!-- ==========================================
       2. CONTENIDO PRINCIPAL DE LA PÁGINA
       ========================================== -->
  <div id="smooth-wrapper">
    <main id="smooth-content">
      <section class="clients">
        <div class="clients-header">
          <div
            style="opacity: 1; 
            class="
            pos-1
            typing-indicator"
            data-alt-pos="pos-3"
            data-scramble-duration="0"
            "
          >
            █
          </div>
        </div>

        <div class="clients-preview">
          <!-- Tu imagen por defecto -->
          <video
            id="default-client-img"
            src="/images/EstudioLarco.mp4"
            poster="/images/microsoft.webp"
            autoplay
            loop
            muted
            playsinline
            style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; pointer-events: none;"
          ></video>
        </div>

       
        <div class="grid-4">
          <a
            href="/proyectos/prada"
            class="meta-category client-name text-clientes"><h1>Labs.</h1></a
          >
          <a
            href="/proyectos/EstudioLarco"
            class="meta-category client-name text-clientes"
            ><h1>Estudio Larco</h1></a
          >
          <a
            href="/proyectos/bmw"
            class="meta-category client-name text-clientes"><h1>Heel</h1></a
          >
          <a
            href="/proyectos/bottega"
            class="meta-category client-name text-clientes"><h1>Serres</h1></a
          >
          <a
            href="/proyectos/microsoft"
            class="meta-category client-name text-clientes"><h1>Procolor</h1></a
          >
        </div>
      </section>
      <footer>
        <p>Experiment 626</p>
        <p>&nbsp; &nbsp;</p>
      </footer>
    </main>
  </div>

  <script>
    import "../scripts/main.js";
  </script>
</Layout>

<!-- ==========================================
     3. EL CSS MÁGICO PARA EL EFECTO DE FONDO
     ========================================== -->
<style>
  /* Convierte todo el bloque de texto en un fondo fantasma */
  .bg-decorative {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0; /* Lo manda detrás de la sección de clientes */
    opacity: 0.3; /* Súper tenue, ajusta este valor a tu gusto (ej: 0.05 para más sutil) */
    pointer-events: none; /* CLAVE: Evita que el usuario seleccione este texto o interfiera con los links de los clientes */
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* Asegura que los textos internos no rompan el contenedor */
  .bg-decorative .content {
    transform: scale(
      0.5
    ); /* Lo encogemos un poco para que sea un buen patrón de fondo */
    width: 100%;
    height: 100%;
  }

  /* Aseguramos que la sección de clientes esté siempre POR ENCIMA de la decoración */
  .clients {
    position: relative;
    z-index: 10;
  }
</style>
<style>
  /* VARIABLES GLOBALES (Para mantener la consistencia) */
  :root {
    --color-bg-dark: #ebe9e5;
    --color-text-main: #0a0a0a;
    --color-text-muted: #4a4a4a;
    --border-subtle: 1px solid rgba(255, 255, 255, 0.1);
  }

  .interior-page {
    background-color: var(--color-bg);
    color: var(--color-text-muted);
    padding: 8rem 4rem; /* Aire a los bordes de la pantalla */
    /* Reemplaza con tu tipografía */
  }

  /* LA GRILLA MAESTRA DE 4 COLUMNAS */
  .grid-4 {
    margin: auto;
    margin-bottom: 50px;
    width: 90%;
    display: flex;
    gap: 2rem;
    justify-content: space-around;
    align-items: baseline;
    
  }

  /* --- 1. CABECERA PRINCIPAL --- */
  .page-header {
    margin-bottom: 8rem; /* Separación masiva típica editorial */
  }

  .main-headline {
    grid-column: 3 / -1; /* Ocupa desde la 3ra columna hasta el final */
    font-size: clamp(2rem, 3.5vw, 4rem); /* Texto fluido */
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  /* --- 2. ETIQUETAS DE SECCIÓN --- */
  .section-labels {
    margin-bottom: 4rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .label-date {
    grid-column: 2 / 3;
  }
  .label-title {
    grid-column: 3 / 4;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text-main);
    margin: 0;
  }

  /* --- 3. PROYECTO --- */
  .project-item {
    border-top: 1px solid var(--color-text-muted); /* La línea fina superior */
    padding-top: 2rem;
  }

  .project-meta {
    margin-bottom: 3rem;
  }

  .meta-year {
    font-size: 0.75rem;
    font-weight: 500;
  }

  .meta-title {
    font-size: 1.75rem;
    font-weight: 600;
    margin: 0;
  }

  .meta-desc {
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--color-text-muted);
    grid-column: 3 / -1; /* Ocupa desde la 3ra columna hasta el final */
    max-width: 90%; /* Evita que el texto llegue hasta el borde de su columna */
  }

  .meta-category {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-align: right; /* Alineado a la derecha como en el diseño */
  }

  /* LA IMAGEN HERO */
  .project-image {
    width: 100%;
    border-radius: 20px; /* Bordes redondeados del diseño */
    overflow: hidden;
    background-color: #1a1a1a; /* Placeholder por si la imagen tarda */
  }

  .project-image img {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9; /* Mantiene la proporción cinemática */
    object-fit: cover;
    display: block;
  }

  .project-image video {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9; /* Mantiene la proporción cinemática */
    object-fit: cover;
    display: block;
  }

  /* --- RESPONSIVE (Móviles) --- */
  @media (max-width: 900px) {
    .interior-page {
      padding: 4rem 1.5rem;
    }

    /* Rompemos la grilla a 1 sola columna en móviles */
    .grid-4 {
      width: 80%;
      display: grid;
      margin-bottom: 6rem;
      grid-template-columns:auto;   
      justify-content: flex-start;
      gap:0px; 
      
    }
    


    .meta-category {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0;
    
  }

    .main-headline {
      grid-column: 1 / -1;
    }
    .label-date,
    .label-title {
      grid-column: 1 / -1;
    }

    .meta-category {
      text-align: left;
      margin-top: 1rem;
    }

  }
</style>
