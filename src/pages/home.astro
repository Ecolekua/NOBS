---
// src/pages/home.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Inicio - No Brand Studio">
  
  <header class="frame">
  
  </header>
<div class="logo fixed">
      <span class="dif">No Brand Studio.</span>
    </div>
  <!-- ==========================================
       1. TU CÓDIGO DECORATIVO DE FONDO AQUÍ
       ========================================== -->
  <div class="bg-decorative">
     <div class="group">
          <div class="el pos-3" data-alt-pos="pos-8">Dormant voltage</div>
		 <div class="el pos-3 typing-indicator" data-alt-pos="pos-3" data-scramble-duration="0">█</div>
          <a class="el pos-3" data-alt-pos="pos-3" data-scramble-duration="0"> Chilean UX Design studio.</a>
          
       
      <h1 class="frame__title  flex-end">
		 <div class="el pos-1 typing-indicator" data-alt-pos="pos-3" data-scramble-duration="0">█</div>
       
      
       
      </h1>
      <a class="frame__archive el pos-2" href="https://tympanus.net/codrops/hub/">All demos</a>
       
                      
      <a class="frame__github el pos-2" href="#">GitHub</a>
      <nav class="frame__tags el pos-2">
        <a href="#">#scroll</a>
        <a href="#">#typography</a>
        <a href="#">#gsap</a>
      </nav>
    </div>
    

    <!-- Contenedor de todos los textos animados -->
    <div class="content">
      <div class="group">
    <div class="el pos-4" data-alt-pos="pos-2">Signal</div>
    <div class="el pos-4" data-alt-pos="pos-2">Vacant orbit</div>
    <div class="el pos-4" data-alt-pos="pos-2">Quantum waves</div>
  </div>
  <div class="group">
    <div class="el pos-1" data-alt-pos="pos-3">Neural glow</div>
    <div class="el pos-1" data-alt-pos="pos-3">Micro distortions</div>
    <div class="el pos-1" data-alt-pos="pos-3">Data streams</div>
    <div class="el pos-1" data-alt-pos="pos-3">Spark</div>
    <div class="el pos-1" data-alt-pos="pos-3">Cold radiance</div>
  </div>
  
  <div class="group">
    <div class="el el--xl pos-1" data-alt-pos="pos-2" data-scramble-duration="2.5">M</div>
  </div>
  <div class="group">
    <div class="el pos-1" data-alt-pos="pos-3" data-scramble-duration="0"> </div>
    <div class="el pos-1 typing-indicator" data-alt-pos="pos-3" data-scramble-duration="0"> </div>
  </div>
      <div class="group">
        <div class="el pos-4" data-alt-pos="pos-2">Signal</div>
        <div class="el pos-4" data-alt-pos="pos-2">Vacant orbit</div>
        <div class="el pos-4" data-alt-pos="pos-2">Quantum waves</div>
      </div>
      <div class="group">
        <div class="el pos-1" data-alt-pos="pos-3">Neural glow</div>
        <div class="el pos-1" data-alt-pos="pos-3">Micro distortions</div>
        <div class="el pos-1" data-alt-pos="pos-3">Data streams</div>
        <div class="el pos-1" data-alt-pos="pos-3">Spark</div>
        <div class="el pos-1" data-alt-pos="pos-3">Cold radiance</div>
      </div>
      <!-- ... Continúa pegando los demás grupos aquí ... -->
    </div>

  </div>
  <!-- FIN DE LA DECORACIÓN -->

  <!-- ==========================================
       2. CONTENIDO PRINCIPAL DE LA PÁGINA
       ========================================== -->
  <div id="smooth-wrapper">
    <main id="smooth-content">
      
      <section class="clients" style="padding-top: 15vh;">
        <div class="clients-header">
          <p>Trusted Us</p>
        </div>
        
        <div class="clients-list">
          <div class="client-name logo"><h1>Apple,</h1></div>
          <div class="client-name logo"><h1>BMW,</h1></div>
          <div class="client-name logo"><h1>Bottega,</h1></div>
          <div class="client-name logo"><h1>Microsoft,</h1></div>
          <div class="client-name logo"><h1>Prada.</h1></div>
        </div>
        
        <div class="clients-preview">
          <!-- Tu imagen por defecto -->
          <img 
            id="default-client-img" 
            src="/images/apple.webp" 
            alt="Default Background" 
            style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; pointer-events: none;"
          />
        </div> 
      </section>

      <footer>
        <p>Experiment 626</p>
        <p>:D</p>
      </footer>

    </main>
  </div>

  <script>
    import "../scripts/main.js";
  </script>
</Layout>

<!-- ==========================================
     3. EL CSS MÁGICO PARA EL EFECTO DE FONDO
     ========================================== -->
<style>
  /* Convierte todo el bloque de texto en un fondo fantasma */
  .bg-decorative {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0; /* Lo manda detrás de la sección de clientes */
    opacity: 0.3; /* Súper tenue, ajusta este valor a tu gusto (ej: 0.05 para más sutil) */
    pointer-events: none; /* CLAVE: Evita que el usuario seleccione este texto o interfiera con los links de los clientes */
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* Asegura que los textos internos no rompan el contenedor */
  .bg-decorative .content {
    transform: scale(0.5); /* Lo encogemos un poco para que sea un buen patrón de fondo */
    width: 100%;
    height: 100%;
  }

  /* Aseguramos que la sección de clientes esté siempre POR ENCIMA de la decoración */
  .clients {
    position: relative;
    z-index: 10;
  }
</style>