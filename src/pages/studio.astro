---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="studio">
    <div class="col">
      <h2 class="studio-header">Our Story</h2>
    </div>
    <div class="col">
      <div class="animate-text">
        En No Brand Studio, entendemos que la creatividad no es solo una habilidad, sino una forma de pensar. Nacimos en Chile a partir de una convicción: diseñar con intención, 
        desafiando lo obvio y construyendo experiencias significativas. Somos un estudio multidisciplinario 
        de diseño y tecnología, donde convergen diseño, estrategia y desarrollo para dar vida a productos 
        centrados en la experiencia de usuario.
        Hoy, colaboramos con clientes y equipos que buscan ir más allá de lo convencional,
         desarrollando soluciones digitales, identidades y productos que combinan funcionalidad,
          estética y propósito.
      </div>

      <div class="about-img">
        <img
          src="/studio.jpg"
          alt="Team at work in Nuvoro's creative space"
        />
      </div>
    </div>
  </section>

  <script>
    import { gsap } from 'gsap';
    import { SplitText } from 'gsap/SplitText';

    gsap.registerPlugin(SplitText);

    document.addEventListener('astro:page-load', () => {
      
      const textElements = document.querySelectorAll(".animate-text, .studio-header");
      if (textElements.length === 0) return;

      // 1. Instanciamos SplitText usando la propiedad 'mask'
      // Esto crea automáticamente los divs envolventes con overflow: hidden
      const splitText = new SplitText(textElements, {
        type: "lines",
        linesClass: "line",
        mask: "lines" // ¡La magia ocurre aquí!
      });

      // 2. Posición inicial (oculto hacia abajo, por debajo de la máscara)
      gsap.set(splitText.lines, { y: "110%" });

      // 3. Animación hacia arriba
      gsap.to(splitText.lines, {
        y: "0%",
        duration: 1.5,
        stagger: 0.1,
        delay: 1.5,
        ease: "power4.out",
      });
    });
  </script>

  <style>
    /* Agrega aquí los estilos específicos de la página Studio */
    .studio {
      padding: 15em 1em;
      display: flex;
      gap: 1em;
      background-color: #fff;
      color: #0a0a0a;
      min-height: 100vh;
    }

    .studio .col:nth-child(1) {
      flex: 1;
    }

    .studio .col:nth-child(2) {
      flex: 2;
      display: flex;
      flex-direction: column;
      gap: 2em;
    }

    .about-img {
      aspect-ratio: 5/7;
      overflow: hidden;
    }

    .about-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    @media (max-width: 900px) {
      .studio {
        flex-direction: column;
      }
    }
  </style>
</Layout>