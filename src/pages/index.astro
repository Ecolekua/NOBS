---
import Layout from "../layouts/Layout.astro";
---

<Layout title="On-Scroll Text Motion | Codrops">


  <div class="group">
          <div class="el pos-3" data-alt-pos="pos-8">Dormant voltage</div>
		 <div class="el pos-3 typing-indicator" data-alt-pos="pos-3" data-scramble-duration="0">█</div>
          <a class="el pos-3" data-alt-pos="pos-3" data-scramble-duration="0"> Chilean UX Design studio.</a>
          
       
      <h1 class="frame__title  flex-end">
		 <div class="el pos-1 typing-indicator" data-alt-pos="pos-3" data-scramble-duration="0">█</div>
       
      
        <a class="nav el pos-3" href="https://www.instagram.com/p/DQkL7XUjEtN/">No Brand studio.</a>
      </h1>
      <a class="frame__archive el pos-2" href="https://tympanus.net/codrops/hub/">All demos</a>
       
                      
      <a class="frame__github el pos-2" href="#">GitHub</a>
      <nav class="frame__tags el pos-2">
        <a href="#">#scroll</a>
        <a href="#">#typography</a>
        <a href="#">#gsap</a>
      </nav>
    </div>

