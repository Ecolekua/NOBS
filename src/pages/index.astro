---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Preloader from '../components/Preloader.astro';
---

<Layout title="Intro - No Brand Studio">
  
  <style>
    body { background-color: var(--color-bg); }
    .fade-out-layer {
      position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
      background-color: var(--color-bg); z-index: 9999;
      opacity: 0; pointer-events: none;
    }
  </style>

  <div class="fade-out-layer" id="fade-layer"></div>

  <!-- 1. VOLVEMOS A PONER TUS IMÁGENES DE FONDO AQUÍ -->
  <div class="logo fixed">
    <span class="dif">No Brand Studio.</span>
  </div>
  <div class="image-sequence-fixed fixed image-thumbnail-wrapper logo">
    <img id="scroll-image" src="/images/apple.webp" alt="Secuencia" />
  </div>

  <div id="smooth-wrapper">
    <main id="smooth-content">
      
      <Preloader /> 
      
      <!-- 2. EL SECRETO: Un bloque invisible gigante que reemplaza el espacio 
           que antes ocupaban tus clientes. Esto le da a GSAP la "pista" para hacer scroll -->
      <div style="height: 250vh; width: 100%;"></div>

    </main>
  </div>

  <script>
    import "../scripts/main.js";
  </script>

  <!-- 3. SCRIPT BLINDADO DE REDIRECCIÓN -->
  <script is:inline>
    document.addEventListener('astro:page-load', () => {
      if (window.location.pathname !== '/') return;

      // Bloqueamos la interacción sin romper el scroll
      document.body.style.pointerEvents = "none";

      setTimeout(() => {
        const gsap = window.gsap || window['gsap'];
        
        // PLAN B: Si ocurre un error catastrófico y GSAP no carga, redirigimos al instante
        if (!gsap) {
          window.location.href = "/home";
          return;
        }

        // Calculamos la nueva altura con nuestro espaciador
        let maxScroll = 0;
        if (window.miSmoother) {
            maxScroll = window.miSmoother.content().offsetHeight - window.innerHeight;
        } else {
            maxScroll = document.documentElement.scrollHeight - window.innerHeight;
        }

        // Si la página es muy corta por error, forzamos un mínimo de scroll matemático
        if (maxScroll < 500) maxScroll = 2500;

        // Le decimos al motor que baje hasta el fondo
        const targetObj = window.miSmoother ? window.miSmoother : window;
        const scrollProp = window.miSmoother ? "scrollTop" : "scrollTo";

        gsap.to(targetObj, {
          [scrollProp]: maxScroll,
          duration: 3,
          ease: "power2.inOut",
          onComplete: () => {
            // Se funde a negro al terminar
            gsap.to("#fade-layer", {
              opacity: 1,
              duration: 0.3,
              ease: "power2.inOut",
              onComplete: () => {
                // Redirección inmaculada
                window.location.href = "/home";
              }
            });
          }
        });
      }, 1000); // 1 segundo de respiro antes de iniciar
    });
  </script>

</Layout>